# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase service role key — server-only, never exposed to the browser.
# Project Settings → API → service_role secret.
# Also powers app-level login lockout (writes to the RLS-protected
# auth_attempts table). Without it, lockout gracefully no-ops.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — used server-side only to generate pet-voice text (gpt-4o-mini).
# If omitted, the app falls back to templated pet-voice copy so it still runs.
OPENAI_API_KEY=sk-your-openai-key

# --- Notifications -------------------------------------------------------------
# Secret for the scheduled reminders endpoint (POST /api/cron/reminders with
# `Authorization: Bearer <CRON_SECRET>`). Required for the endpoint to run.
CRON_SECRET=choose-a-long-random-string

# Email delivery. With NONE of these set, email is delivered to the LOCAL Mailpit
# SMTP so messages appear at http://127.0.0.1:54324. Set a provider to send real
# email (Resend preferred, else SendGrid). All are server-only.
# RESEND_API_KEY=re_your-resend-key
# SENDGRID_API_KEY=SG.your-sendgrid-key
# NOTIFY_FROM="PawScript <no-reply@yourdomain.com>"

# Local mock SMTP (Supabase Mailpit). Defaults shown; only override if changed.
# MOCK_SMTP_HOST=127.0.0.1
# MOCK_SMTP_PORT=54325

# SMS delivery. Without Twilio creds, SMS is a mock that logs to the server
# console (and falls back to email when a verified phone is missing).
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM=+15551234567
