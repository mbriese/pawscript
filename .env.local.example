# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase service role key — server-only, never exposed to the browser.
# Project Settings → API → service_role secret.
# Also powers app-level login lockout (writes to the RLS-protected
# auth_attempts table). Without it, lockout gracefully no-ops.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — used server-side only to generate pet-voice text (gpt-4o-mini).
# If omitted, the app falls back to templated pet-voice copy so it still runs.
OPENAI_API_KEY=sk-your-openai-key
